# Pimenta API environment — copy to /etc/pimenta-api/pimenta-api.env
# Protect it:  sudo chmod 600 /etc/pimenta-api/pimenta-api.env

# Bind address & port. Keep HOST on localhost; Apache reverse-proxies to it.
HOST=127.0.0.1
PORT=3000

# Strong random secret used to sign JWTs. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_TTL=2h

# Where the SQLite database file lives (persists across restarts/reboots).
# When run under systemd with StateDirectory=pimenta-api this maps to
# /var/lib/pimenta-api.
DB_PATH=/var/lib/pimenta-api/pimenta.db

# Seed admin account (created only if the users table is empty).
ADMIN_EMAIL=admin@juice-sh.op
ADMIN_PASSWORD=admin123

# Allowed CORS origins (comma-separated). The frontend (shop/www) calls this
# API cross-origin, so its domains must be listed. Requests with no Origin
# header (curl, server-to-server) are always allowed.
CORS_ORIGINS=https://www.pimenta.fun,https://shop.pimenta.fun,https://api.pimenta.fun
