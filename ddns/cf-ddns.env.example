# cf-ddns configuration — copy to /etc/cf-ddns/cf-ddns.env and fill in.
# Keep this file readable only by root:  chmod 600

# Cloudflare API token with permission: Zone > DNS > Edit  (scoped to pimenta.fun)
CF_API_TOKEN="paste-your-scoped-api-token-here"

# The zone (root domain) that holds the records.
CF_ZONE_NAME="pimenta.fun"

# Optional: hard-code the Zone ID to skip a lookup API call (found on the
# Cloudflare dashboard Overview page). Leave blank to auto-resolve by name.
CF_ZONE_ID=""

# Space-separated list of hostnames (A records) to keep in sync.
RECORDS="www.pimenta.fun shop.pimenta.fun"

# Record settings
TTL="120"        # seconds (use 1 for "Auto")
PROXIED="false"  # "true" to proxy through Cloudflare (orange cloud), "false" = DNS only

# Where to write logs
LOG_FILE="/var/log/cf-ddns.log"
